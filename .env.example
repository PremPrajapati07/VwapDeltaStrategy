# ============================================================
#  .env.example — Copy this to .env and fill in your values
#  NEVER commit .env to git!
# ============================================================

# ── Zerodha Kite Credentials ──────────────────────────────────
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# ── Kite Login (for auto-login) ──────────────────────────────
KITE_USER_ID=your_zerodha_user_id       # e.g. AB1234
KITE_PASSWORD=your_zerodha_password
KITE_TOTP_SECRET=your_totp_secret_key   # 32-char base32 key from Kite TOTP setup

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/trading

# ── Optional Overrides ────────────────────────────────────────
# If KITE_ACCESS_TOKEN is set (and still valid for today), auto-login is skipped
KITE_ACCESS_TOKEN=

# --- KOTAK NEO CREDENTIALS ---
ENABLE_KOTAK=True
NEO_CONSUMER_KEY=
NEO_CONSUMER_SECRET=
NEO_USER_ID=
NEO_PASSWORD=
NEO_MPIN=
NEO_ENVIRONMENT=prod

